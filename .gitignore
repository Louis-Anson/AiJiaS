# ============================================================
# AiJiaS — .gitignore
# ============================================================

# Secrets — NEVER commit
.env
docker-compose/.env
home-assistant/secrets.yaml
*.pem
*.key
acme.json

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# Docker runtime (if any end up in repo)
docker-compose/letsencrypt/
/share/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Node
node_modules/

# Backup & temp
*.bak
*.tmp
*.log

# OS
.directory
