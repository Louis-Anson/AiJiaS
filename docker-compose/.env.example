# ============================================================
# AiJiaS Docker 环境变量配置模板
# 复制为 .env 并填入实际值
# ============================================================

# ==================== 域名 ====================
DOMAIN_EXTERNAL=relax.mycloudnas.com
DOMAIN_INTERNAL=relax.local
LETSENCRYPT_EMAIL=your@email.com

# ==================== PostgreSQL ====================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=aijias

# ==================== Redis ====================
REDIS_PASSWORD=your_redis_password_here

# ==================== AI 模型 API Keys ====================
DEEPSEEK_API_KEY=sk-xxx
KIMI_API_KEY=sk-xxx
ZHIPU_API_KEY=xxx
OPENAI_API_KEY=sk-xxx
OPENAI_API_BASE=https://api.4sapi.com/v1
OPENROUTER_API_KEY=sk-or-xxx

# ==================== LiteLLM ====================
LITELLM_MASTER_KEY=sk-litellm-master-key
LITELLM_SALT_KEY=litellm-salt-key
LITELLM_DB_PASSWORD=

# ==================== Home Assistant ====================
HOME_ASSISTANT_URL=http://192.168.x.x:8123
HA_LONG_LIVED_ACCESS_TOKEN=eyJ...

# ==================== ntfy ====================
NTFY_TOKEN=your_ntfy_token

# ==================== Mealie ====================
MEALIE_DB_PASSWORD=your_mealie_password

# ==================== Firefly III ====================
FIREFLY_APP_KEY=$(head -c 32 /dev/urandom | base64)
FIREFLY_DB_PASSWORD=your_firefly_password

# ==================== LubeLogger ====================
LUBELOGGER_DB_PASSWORD=your_lubelogger_password

# ==================== Immich ====================
IMMICH_DB_USER=immich
IMMICH_DB_PASSWORD=your_immich_password
IMMICH_DB_NAME=immich

# ==================== Vaultwarden ====================
VAULT_ADMIN_TOKEN=your_vault_admin_token
VAULT_SIGNUPS_ALLOWED=true

# ==================== Donetick ====================
# JWT Secret（用于用户认证，生成命令：openssl rand -base64 32）
DT_JWT_SECRET=Sr09TL...生成后填入

# ==================== Homebox ====================
# API Key Pepper（生成命令：openssl rand -base64 48）
HBOX_AUTH_API_KEY_PEPPER=nV2vy2...生成后填入

# ==================== Period Predictor ====================
PERIOD_PREDICTOR_IMAGE=aijias/period-predictor:latest
