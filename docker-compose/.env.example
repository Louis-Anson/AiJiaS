# AiJiaS Docker Compose — 环境变量模板
# 复制为 .env 后修改所有占位值
# ================================================================

# ================================================================
# 1. 公网域名 & TLS
# ================================================================
DOMAIN_EXTERNAL=relax.mycloudnas.com
DOMAIN_INTERNAL=relax.local
LETSENCRYPT_EMAIL=louis_anson@163.com

TZ=Asia/Shanghai

# ================================================================
# 2. 主数据库 (PostgreSQL + Redis + PgBouncer)
# ================================================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=aijias

REDIS_PASSWORD=change-me-strong-password

# ================================================================
# 3. 各服务 PostgreSQL 用户密码 (共享主库, 各自独立 database + user)
# ================================================================
IMMICH_DB_PASSWORD=immich_强密码
MEALIE_DB_PASSWORD=mealie_强密码
FIREFLY_DB_PASSWORD=firefly_强密码
FIREFLY_APP_KEY=base64_32位随机字符串
LUBELOGGER_DB_PASSWORD=lubelogger_强密码

IMMICH_DB_USER=immich
IMMICH_DB_NAME=immich

# ================================================================
# 4. 内部服务 HTTP API Token
#    内部服务之间互相调用时通过 Bearer Token 鉴权
# ================================================================
HERMES_API_KEY=hermes_change_me_32位随机字符串
NTFY_TOKEN=ntfy_change_me_32位随机字符串
LITELLM_MASTER_KEY=litellm_master_密钥_32位base64
LITELLM_SALT_KEY=litellm_salt_密钥_32位base64

# ================================================================
# 5. AI 模型供应商密钥
# ================================================================
# DeepSeek 官方（直连，用于 daily_zh / tool_strict / planner / skill_evolver）
DEEPSEEK_API_KEY=

# 4SAPI 中转站（用于 Opus / Sonnet / GPT）
# 也用于 Hermes Agent 的 LLM_API_KEY
OPENAI_API_KEY=
OPENAI_API_BASE="https://4sapi.com"

# OpenRouter（用于 Nemotron 3 Ultra 免费兜底）
# 申请地址：https://openrouter.ai/
OPENROUTER_API_KEY=


# Kimi 官方（直连，用于 care_warm，官方直连，中文情感表达最自然）
# 申请地址：https://platform.moonshot.cn/
KIMI_API_KEY=
KIMI_API_BASE=https://api.moonshot.cn/v1

# 智谱 AI 官方（直连，用于 daily_zh 负载均衡 + fast_aux，Beta 免费）
# 申请地址：https://open.bigmodel.cn/
ZHIPU_API_KEY=

# ================================================================
# 6. 企业微信 / 微信 (AI Assistant Gateway)
# ================================================================
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_TOKEN=
WECOM_AES_KEY=

# ================================================================
# 7. Home Assistant
# ================================================================
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HA_LONG_LIVED_ACCESS_TOKEN=***
# ================================================================
# 8. Vaultwarden — 家庭密码管理器
# ================================================================
# 首次部署时设为 true 允许注册，创建账号后建议改为 false
VAULT_SIGNUPS_ALLOWED=true
# Admin 后台 Token：用 `openssl rand -base64 48` 生成，访问 /admin 时使用
VAULT_ADMIN_TOKEN=your_admin_token_here
# ================================================================
# 9. 家庭系统服务内部 URL（Hermes Agent 直接调用）
# ================================================================
MEALIE_BASE_URL=http://mealie:9000
