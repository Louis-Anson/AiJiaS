# AiJiaS Docker Compose environment example

# ==================== Public entrance ====================
AI_GATEWAY_HOST=assistant.example.com
LETSENCRYPT_EMAIL=you@example.com

# ==================== Self-built AiJiaS images ====================
# These images are enabled by Docker Compose profiles after each module is implemented.
# gateway: AI_GATEWAY_IMAGE + SERVICE_ADAPTER_IMAGE
# agent: HERMES_IMAGE + SERVICE_ADAPTER_IMAGE
# skills: SKILL_REGISTRY_IMAGE + SKILL_MINER_IMAGE
# health: PERIOD_PREDICTOR_IMAGE
AI_GATEWAY_IMAGE=aijias/ai-assistant-gateway:latest
HERMES_IMAGE=aijias/hermes-runtime:latest
SKILL_REGISTRY_IMAGE=aijias/skill-registry:latest
SERVICE_ADAPTER_IMAGE=aijias/service-adapter:latest
SKILL_MINER_IMAGE=aijias/skill-miner:latest
PERIOD_PREDICTOR_IMAGE=aijias/period-predictor:latest

# ==================== Databases ====================
DB_USER=aijias
DB_PASSWORD=change-me-strong-password
AIJIAS_DB_NAME=aijias

# ==================== WeCom / WeChat ====================
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_TOKEN=
WECOM_AES_KEY=

# ==================== LiteLLM model keys ====================
LITELLM_MASTER_KEY=sk-change-me
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

# ==================== Internal service API keys ====================
DONETICK_API_KEY=
GROCY_API_KEY=
EZBOOKKEEPING_TOKEN=
HOMEBOX_TOKEN=
IMMICH_API_KEY=
NAVIDROME_USERNAME=
NAVIDROME_PASSWORD=

# ==================== Home Assistant ====================
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HA_LONG_LIVED_ACCESS_TOKEN=

# ==================== Family systems ====================
PUID=1000
PGID=1000
MEALIE_BASE_URL=http://mealie:9000
TANDOOR_SECRET=change-me-tandoor-secret
TREK_JWT_SECRET=change-me-trek-secret

# ==================== Immich ====================
IMMICH_DB_USER=immich
IMMICH_DB_PASSWORD=change-me-immich-password
IMMICH_DB_NAME=immich
