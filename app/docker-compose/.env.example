# AiJiaS — 家物 OS 环境变量模板
# 复制为 docker-compose/.env 并填入实际值

# 域名
DOMAIN_EXTERNAL=relax.mycloudnas.com

# Core — 业务核心
MEALIE_DB_PASSWORD=your_mealie_db_password
FIREFLY_APP_KEY=your_firefly_app_key
FIREFLY_DB_PASSWORD=your_firefly_db_password
LUBELOGGER_DB_PASSWORD=your_lubelogger_db_password
DT_JWT_SECRET=your_donetick_jwt_secret
HBOX_AUTH_API_KEY_PEPPER=your_homebox_pepper
PERIOD_PREDICTOR_IMAGE=aijias/period-predictor:latest

# Infra — 基础服务
NTFY_TOKEN=your_ntfy_token
VAULT_ADMIN_TOKEN=your_vault_admin_token
VAULT_SIGNUPS_ALLOWED=true
